# Telegram bot token from @BotFather
BOT_TOKEN=123456:replace_me

# PostgreSQL DSN (required for normal run)
# Example local URL:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rent_room

# JWT settings
JWT_SECRET_KEY=change_me_super_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Admin credentials (seeded on startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# Mini app URL shown to users in bot
MINI_APP_URL=http://localhost:8000/miniapp

# Where uploaded files are stored
UPLOAD_DIR=uploads

# DB startup behavior
DB_STARTUP_RETRY_COUNT=5
DB_STARTUP_RETRY_DELAY_SECONDS=1.5
DB_FAIL_FAST_ON_STARTUP=true
